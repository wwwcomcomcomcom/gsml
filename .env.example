# ─── Core ───────────────────────────────────────────────
APP_TIMEZONE=Asia/Seoul
CORS_ORIGINS=http://localhost:5173

# ─── Upstream LLM (llama-server or vLLM) ───────────────
UPSTREAM_BASE_URL=http://host.docker.internal:8080
UPSTREAM_TIMEOUT=600

# ─── DataGSM OAuth ─────────────────────────────────────
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback
OAUTH_AUTH_BASE=https://oauth.authorization.datagsm.kr
OAUTH_RESOURCE_BASE=https://oauth.resource.datagsm.kr

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=24

# ─── API Key ───────────────────────────────────────────
API_KEY_EXPIRE_DAYS=30

# ─── Defaults for new users ────────────────────────────
DEFAULT_USAGE_LIMIT=100000
DEFAULT_MAX_CONCURRENT=2

# ─── Logs ──────────────────────────────────────────────
REQUEST_LOG_RETENTION_DAYS=30

# ─── Database ──────────────────────────────────────────
DATABASE_URL=sqlite:///./data/gsml.db
